{
  "expo": {
    "name": "Top Congo",
    "slug": "top-congo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-red-white.png",
    "scheme": "topcongomobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-red-white.png",
      "bundleIdentifier": "app.topcongo.live",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#B10018",
        "foregroundImage": "./assets/images/android-icon-foreground-white-padded.png",
        "monochromeImage": "./assets/images/android-icon-monochrome-white-padded.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.topcongo.live",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "androidStatusBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#174197",
          "image": "./assets/images/splash-logo-padded.png",
          "imageWidth": 260
        }
      ],
      "expo-localization",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "general",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "organization": "archi-tech",
          "project": "top-congo-mobile"
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc8f0f8e-04f6-4bd0-b364-150c88764eba"
      }
    }
  }
}
